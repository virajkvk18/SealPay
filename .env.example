NEXT_PUBLIC_ENABLE_MOCK_MODE=false
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_CONTRACT_ADDRESS=
PRIVATE_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Groq config for real AI proof/dispute review.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Server-only Pinata config for real proof uploads. PINATA_JWT is required
# for Teammate 4's IPFS proof flow.
PINATA_JWT=
NEXT_PUBLIC_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# Server-only security controls. Do not prefix secrets or private config with NEXT_PUBLIC_.
SECURITY_RATE_LIMIT_WINDOW_MS=60000
SECURITY_PAGE_RATE_LIMIT=180
SECURITY_API_RATE_LIMIT=60
SECURITY_SENSITIVE_RATE_LIMIT=20
SECURITY_RATE_LIMIT_DISABLED=false

# Polygon Amoy Testnet is the intended contract integration target.
