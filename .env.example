NEXT_PUBLIC_ENABLE_MOCK_MODE=true
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Server-only security controls. Do not prefix secrets or private config with NEXT_PUBLIC_.
SECURITY_RATE_LIMIT_WINDOW_MS=60000
SECURITY_PAGE_RATE_LIMIT=180
SECURITY_API_RATE_LIMIT=60
SECURITY_SENSITIVE_RATE_LIMIT=20
SECURITY_RATE_LIMIT_DISABLED=false

# Polygon Amoy Testnet is the intended future integration target.
# The current MVP runs fully in mock mode without a deployed contract.
